{
  "rules": {
    ".read": true,
    ".write": "auth != null",

    "students": {
      ".write": "auth != null"
    },

    "posts": {
      "$id": {
        ".write": "auth != null || newData.exists()",
        ".validate": "!newData.hasChild('content') || (newData.child('content').isString() && newData.child('content').val().length <= 3000)"
      }
    },
    "goryeo_v2": {
      "$id": {
        ".write": "auth != null || newData.exists()",
        ".validate": "!newData.hasChild('content') || (newData.child('content').isString() && newData.child('content').val().length <= 3000)"
      }
    },
    "goryeo_results": {
      "$id": {
        ".write": "auth != null || !data.exists()",
        ".validate": "!newData.hasChild('reflection') || (newData.child('reflection').isString() && newData.child('reflection').val().length <= 3000)"
      }
    },
    "goryeo_settings": { ".write": "auth != null" },
    "goryeo_grades": { ".write": "auth != null" },
    "goryeo_ai_cache": { ".write": "auth != null" },
    "silla_toast": { ".write": "auth != null" },
    "goryeo_v2_toast": { ".write": "auth != null" },
    "adminConfig": { ".write": "auth != null" },

    "historyMileage": {
      "studyCert": {
        "$id": {
          ".write": "auth != null || newData.exists()"
        }
      },
      "studentPw": {
        "$id": {
          ".write": true,
          ".validate": "newData.isString() && newData.val().length <= 100"
        }
      },
      "mileage": {
        "$id": {
          ".write": true,
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000"
        }
      },
      "totalEarned": {
        "$id": {
          ".write": true,
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000"
        }
      }
    },

    "status": {
      "$key": {
        "$missionId": {
          ".write": "auth != null || newData.exists()"
        }
      }
    },
    "status1": {
      "$key": {
        "$missionId": {
          ".write": "auth != null || newData.exists()"
        }
      }
    },
    "missionEdit1": { ".write": "auth != null" },
    "missionData": { ".write": "auth != null" },
    "markerPositions": { ".write": "auth != null" },
    "settings": { ".write": "auth != null" }
  }
}
